[Script]
网络信息 = type=generic,timeout=40,script-path=https://github.com/h05n/waibucangku/raw/main/网络信息.js

[Panel]
# 字典默认缓存 7 天。如需立即同步 GitHub 的最新修改：
# 1. 临时加上强制刷新参数跑一次：
# 网络信息面板 = script-name=网络信息, update-interval=1, argument=flush=1
# 2. 刷新成功后务必改回原样（去掉 argument），恢复缓存机制。

网络信息面板 = script-name=网络信息, update-interval=1
