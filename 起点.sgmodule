#!name=起点纯净版段评 (云端热更新版)
#!desc=从 GitHub 实时拉取纯净版 HTML，无缝替换起点的段评页面。以后想改代码直接在 GitHub 上改，手机端无需任何操作即刻生效！
#!system=ios

[Script]
# 拦截段评网页，呼叫 JS 脚本去 GitHub 下载你的代码并替换
起点云端替换 = type=http-response, pattern=^https?:\/\/qdcomment\.b23\.host\/reviews.*, requires-body=1, max-size=3145728, script-path=qidian_inject.js

[MITM]
# 允许 Surge 解密起点的段评连接
hostname = %APPEND% qdcomment.b23.host
